<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <!-- 1. Tabela zgodna z JSON-em -->
    <changeSet id="1-create-spatial-routes" author="eskate">
        <createTable tableName="routes">
            <column name="id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="total_distance" type="DECIMAL(15,2)"> <!-- Zwiększone, bo w JSON masz 66723 -->
                <constraints nullable="false"/>
            </column>
            <column name="unit" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="path" type="GEOMETRY">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- 2. Indeks (Tylko dla MySQL, żeby nie psuć buildu na H2) -->
    <changeSet id="2-add-spatial-index" author="eskate" dbms="mysql">
        <createIndex indexName="idx_routes_path" tableName="routes">
            <column name="path"/>
        </createIndex>
    </changeSet>

<!--     3. Przykładowy INSERT zgodny z Twoim JSON-em-->
    <changeSet id="3-insert-sample-route" author="eskate">
        <insert tableName="routes">
            <column name="id" value="2SxW5tyVD0o"/>
            <column name="name" value="Trasa z dnia 10.05.2026"/>
            <column name="start_date" valueDate="2026-05-10T14:25:10"/>
            <column name="total_distance" valueNumeric="66723"/>
            <column name="unit" value="km"/>
            <column name="path" valueComputed="ST_GeomFromText('LINESTRING(22.248743 52.060687, 22.248743 51.960678, 22.248743 51.860669)', 0)"/>
        </insert>
    </changeSet>

</databaseChangeLog>